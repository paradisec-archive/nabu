{
  "name": "nabu",
  "private": true,
  "dependencies": {
    "@activeadmin/activeadmin": "4.0.0-beta20",
    "@googlemaps/js-api-loader": "^2.0.2",
    "@googlemaps/markerclusterer": "^2.6.2",
    "@sentry/browser": "^10.44.0",
    "choices.js": "^11.0.6",
    "sass": "^1.98.0",
    "tailwindcss": "^4.2.1",
    "uuid": "^13.0.0"
  },
  "scripts": {
    "build": "esbuild app/javascript/*.* --bundle --sourcemap --format=esm --outdir=app/assets/builds --public-path=/assets",
    "build:css": "pnpm build:css_app && pnpm build:css_active_admin",
    "build:css_app": "sass ./app/assets/stylesheets/application.sass.scss:./app/assets/builds/application.css --no-source-map --load-path=node_modules",
    "build:css_active_admin": "npx @tailwindcss/cli -i ./app/assets/stylesheets/active_admin.css -o ./app/assets/builds/active_admin.css --minify"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "esbuild": "^0.27.4"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
